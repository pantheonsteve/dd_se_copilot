{
  "manifest_version": 3,
  "name": "Support Admin Copilot (Demo)",
  "version": "0.1.0",
  "description": "Read-only AI copilot for Datadog Support Admin. Observes, never acts. DEMO ORG ONLY until manager approval for customer use.",

  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage",
    "debugger"
  ],

  "host_permissions": [
    "https://*.datadoghq.com/*",
    "https://*.datad0g.com/*",
    "http://localhost:*/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_title": "Open Support Admin Copilot"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.datadoghq.com/*",
        "https://*.datad0g.com/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
