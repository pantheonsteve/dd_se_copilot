# Company Research Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# The root .env is also loaded; values here take precedence.

SUMBLE_API_KEY=                                # Sumble API — company enrichment, jobs, people
BUILTWITH_API_KEY=                             # BuiltWith API — technology stack detection
SEC_EDGAR_AGENT_URL=http://localhost:5053      # SEC EDGAR RAG agent base URL
PORT=5056
LOG_LEVEL=INFO
