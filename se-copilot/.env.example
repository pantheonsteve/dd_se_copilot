ANTHROPIC_API_KEY=sk-ant-...
TECHNICAL_AGENT_URL=http://localhost:5050/api/query
VALUE_AGENT_URL=http://localhost:5051/api/query
CASE_STUDIES_AGENT_URL=
BUYER_PERSONA_AGENT_URL=
CLAUDE_MODEL=claude-sonnet-4-6
ROUTER_TIMEOUT_SECONDS=10
AGENT_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO

# Homerun DIM / opportunity search (optional — REPORTING.GENERAL.DIM_HOMERUN_OPPORTUNITY)
# Without SNOWFLAKE_ENABLED, “Load from Snowflake” shows disabled; Generate still works.
SNOWFLAKE_ENABLED=false
# connector = snowflake-connector-python + SNOWFLAKE_* below.
# mcp = spawn Snowflake MCP stdio (same command/args as Cursor); auth is whatever the MCP server reads (often SNOWFLAKE_* env).
# Note: Homerun opportunity name search still uses snowflake-connector-python (set connector + credentials for search, or search elsewhere).
SNOWFLAKE_TRANSPORT=connector
SNOWFLAKE_MCP_COMMAND=
# JSON array of strings, e.g. ["snowflake-labs-mcp","--service-config-file","/path/tools_config.yaml","--connection-name","default"]
SNOWFLAKE_MCP_ARGS_JSON=[]
# Optional cwd for uvx/Python MCP subprocess (must exist).
SNOWFLAKE_MCP_CWD=
SNOWFLAKE_MCP_QUERY_TOOL=run_snowflake_query
# Argument name for the SQL string (some MCP servers use "sql").
SNOWFLAKE_MCP_STATEMENT_ARGUMENT=statement
SNOWFLAKE_MCP_TIMEOUT_SECONDS=120
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=REPORTING
SNOWFLAKE_SCHEMA=GENERAL
# Use password OR private key (key wins if both set)
SNOWFLAKE_PASSWORD=
# SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
# --- Gmail / SSO without password (human users) ---
# Cursor MCP can SSO in a browser; SE Copilot cannot reuse that session.
#
# Recommended: Snowflake CLI + same connection name as MCP
#   1) Install Snowflake CLI; add an SSO/OAuth connection (browser login once).
#   2) Set snowflake_default_connection_name + snowflake_client_store_temporary_credential=true below.
#   3) Match SNOWFLAKE_MCP_ARGS_JSON --connection-name to that name.
#   4) When auth expires, run:  python scripts/snowflake_sso_refresh_cli.py  (same OS user as uvicorn).
#
# Alternative: short-lived OAuth bearer (advanced)
#   snowflake_oauth_token_file=/secure/path/token.txt   # single-line access token; refresh via your job
#   (optional) snowflake_oauth_access_token=          # avoids file; expires quickly—prefer file + refresh
SNOWFLAKE_DEFAULT_CONNECTION_NAME=
SNOWFLAKE_AUTHENTICATOR=
SNOWFLAKE_CLIENT_STORE_TEMPORARY_CREDENTIAL=false
SNOWFLAKE_TEMPORARY_CREDENTIAL_CACHE_DIR=
SNOWFLAKE_OAUTH_ACCESS_TOKEN=
SNOWFLAKE_OAUTH_TOKEN_FILE=
# Optional: force CLI binary (brew formula installs ``snow`` in /opt/homebrew/bin)
SNOWFLAKE_SQL_CLI_PATH=
SNOWFLAKE_QUERY_TIMEOUT_SECONDS=15
# Optional: Company Detail → Snowflake tab → Salesforce section (read-only SQL).
# Must contain exactly one placeholder: {SALESFORCE_OPPORTUNITY_ID} (substituted from Homerun DIM).
#
# Wider default for Datadog REPORTING (confirm your role can read GTM + RESTRICTED objects):
# Covers identity, stage/forecast, economics, engagement/sentiment, competition, technical/presales,
# POV + trial flags, documents link, snapshot DATA_DATE.
SNOWFLAKE_SALESFORCE_CONTEXT_SQL=SELECT OPPORTUNITY_ID, OPPORTUNITY_NAME, ACCOUNT_ID, RECORD_TYPE, TYPE, STAGE, STAGE_PLAYBOOK, FORECAST_CATEGORY_NAME, NEXT_STEP, CLOSE_DATE, REP_CLOSE_DATE, DEAL_AMOUNT, NET_NEW_ARR, ENGAGEMENT_LEVEL, ENGAGEMENT_QUALITY, SENTIMENT, PRIMARY_COMPETITOR, COMPETITIVE_STATUS_PRIMARY, SE_COMPETITION, TECHNICAL_PLAN_STATUS, PRODUCTS_IN_SCOPE, CURRENT_ENVIRONMENT_TOOLS, EVALUATION_METHOD, OUTSTANDING_RISKS, TECHNICAL_WIN, HAS_POV_STARTED, POV_STARTED_DATE_TIME, HAS_POV_FINISHED, POV_FINISHED_DATE, IS_TRIAL_STARTED, TRIAL_STARTED_DATE_TIME, LINK_TO_OPPORTUNITY_DOCUMENTS, DATA_DATE FROM REPORTING.GTM.DIM_SFDC_OPPORTUNITY_RESTRICTED WHERE IS_MOST_RECENT_DATE = TRUE AND OPPORTUNITY_ID = '{SALESFORCE_OPPORTUNITY_ID}' LIMIT 50
SNOWFLAKE_SALESFORCE_CONTEXT_ROW_LIMIT=35
