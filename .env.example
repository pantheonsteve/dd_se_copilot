# =============================================================================
# SE Copilot — Root Environment Configuration
# Copy this file to .env and fill in your values.
# Per-service .env files (in se-copilot/, agents/rag/, etc.) can override these.
# =============================================================================

# ---- Required API Keys ----
OPENAI_API_KEY=sk-...                          # OpenAI — used for embeddings (text-embedding-3-small)
ANTHROPIC_API_KEY=sk-ant-...                   # Anthropic — used for Claude LLM across all services

# ---- LLM Model ----
CLAUDE_MODEL=claude-sonnet-4-6

# ---- Agent URLs (defaults assume all services run locally) ----
TECHNICAL_AGENT_URL=http://localhost:5050/api/query       # Librarian RAG agent
VALUE_AGENT_URL=http://localhost:5051/api/query            # Value RAG agent

# Optional agents — leave empty to disable
CASE_STUDIES_AGENT_URL=http://localhost:5052/api/query
SEC_EDGAR_AGENT_URL=http://localhost:5053/api/query
BUYER_PERSONA_AGENT_URL=http://localhost:5054/api/query
SLIDE_AGENT_URL=http://localhost:5055/api/generate-slides
COMPANY_RESEARCH_AGENT_URL=http://localhost:5056/api/research

# ---- Timeouts ----
ROUTER_TIMEOUT_SECONDS=10
AGENT_TIMEOUT_SECONDS=30

# ---- Logging ----
LOG_LEVEL=INFO

# ---- Datadog (optional — LLM Observability and MCP) ----
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com
DATADOG_APP_NAME=se-copilot

# ---- Company Research Agent (optional) ----
SUMBLE_API_KEY=                                # Sumble API — company enrichment, jobs, people
BUILTWITH_API_KEY=                             # BuiltWith API — technology stack detection
